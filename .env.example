# Set to true to block POST /api/auth/register (recommended on production).
DISABLE_PUBLIC_REGISTER=false

PORT=5000
NODE_ENV=development

MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mw1hncz.mongodb.net/attendance_system?retryWrites=true&w=majority&appName=Cluster0

JWT_SECRET=change_this_to_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# Firebase Cloud Messaging (optional — paste full service account JSON on one line)
# Download from Firebase Console → Project Settings → Service accounts → Generate new private key
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Goinfinito SMS (required for forgot-password OTP on production)
# SMS_CLIENT_ID=
# SMS_CLIENT_PASSWORD=
# SMS_SENDER_ID=ECODRIVE
